# Skopíruj tento súbor ako .env.local a vyplň hodnoty z Supabase projektu
# Project Settings > API v Supabase dashboarde

NEXT_PUBLIC_SUPABASE_URL=https://TVOJ-PROJEKT-ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tvoj-anon-key-sem
NEXT_PUBLIC_ADMIN_EMAIL=tvoj@email.com

# Service Role kľúč — potrebný pre API routy (mazanie žiakov, registrácia)
# Project Settings > API > service_role (secret) — NIKDY nezverejňuj!
SUPABASE_SERVICE_ROLE_KEY=tvoj-service-role-key-sem

# URL tvojej nasadenej aplikácie — používa sa pri reset hesla emailoch
# Lokálne: http://localhost:3000
# Produkcia: https://tvoja-domena.vercel.app
NEXT_PUBLIC_SITE_URL=https://tvoja-domena.vercel.app
